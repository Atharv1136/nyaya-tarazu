# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Supabase project REST URL — found in: Project Settings > API > Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key (not the anon key — needed for bulk inserts that bypass RLS)
# Found in: Project Settings > API > Project API keys > service_role
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
